{
  "name": "dadlandprojeto",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "dadlandbackend/**/*.py": [
      "bash -c 'cd dadlandbackend && ./venv/bin/black .'",
      "bash -c 'cd dadlandbackend && ./venv/bin/flake8 .'"
    ],
    "dadlandfrontend/**/*.{js,jsx,ts,tsx}": [
      "bash -c 'cd dadlandfrontend && npm test -- --watchAll=false --findRelatedTests --bail'"
    ]
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  }
}
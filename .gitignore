# ==============================================================================
# 1. ESTRUTURA E GOVERNANÇA (PROTEGER PARA O TEMPLATE)
# ==============================================================================
# Garante que as actions do GitHub e as regras do Husky sempre existam
!.github/
!.husky/
!.env.example

# Ignora os scripts internos de runtime do Husky (ele recria isso sozinho)
.husky/_/

# ==============================================================================
# 2. SEGURANÇA (NUNCA SUBIR)
# ==============================================================================
.env
.env.*
*.env
!.env.example
!dadlandinfra/.env

# ==============================================================================
# 3. BACKEND (dadlandbackend) - Python/Django
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
.venv/
.env/
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
*.log

# ==============================================================================
# 4. FRONTEND (dadlandfrontend) - Node/Next.js
# ==============================================================================
node_modules/
.next/
out/
build/
dist/
.vercel
.swc/
*.tsbuildinfo

# Logs do Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ==============================================================================
# 5. INFRAESTRUTURA (dadlandinfra) - Docker
# ==============================================================================
postgres-data/
pgdata/
docker-compose.override.yml
!docker-compose.override.yml.example

# ==============================================================================
# 6. IDEs & SISTEMA OPERACIONAL
# ==============================================================================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo